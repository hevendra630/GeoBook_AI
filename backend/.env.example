# Server
APP_NAME="GeoBook AI"
ENVIRONMENT="dev"
LOG_LEVEL="INFO"
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Security
JWT_SECRET_KEY="change-me"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL="postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot"

# OpenStreetMap services
# Nominatim requires a valid user-agent identifying your application.
OSM_USER_AGENT="AI-CHATBOT/1.0 (contact: you@example.com)"
OSM_NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
OSM_NOMINATIM_EMAIL="you@example.com"
OSM_PHOTON_BASE_URL="https://photon.komoot.io"
OSM_OVERPASS_URL="https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://overpass.nchc.org.tw/api/interpreter"

# SMTP (optional). If not configured, booking emails are skipped (logged).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# Rate limiting (basic in-memory; for production prefer Redis-backed)
RATE_LIMIT_DEFAULT="60/minute"

